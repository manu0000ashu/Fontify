        if si>=len(stops)-1: c=stops[-1]
        else: c=tuple(int(stops[si][j]*(1-ti)+stops[si+1][j]*ti) for j in range(3))
        gd.line([(i,0),(i,th)],fill=(*c,255))
    alpha_layer=Image.new("L",img.size,0); ImageDraw.Draw(alpha_layer).text((x,y),text,font=f,fill=255)
    result=Image.new("RGBA",img.size,(0,0,0,0)); result.paste(grad,(x,y))
