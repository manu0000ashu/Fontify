def effect_first_letter_highlight(bg, text, size):
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    f,_=fit(od,text,img.width-40,size); tw,_=tbbox(od,text,f); x=(img.width-tw)//2
    f_big=gf(int(size*1.5)); f_small=gf(size)
    _,th_big=tbbox(od,text[0],f_big); _,th_sm=tbbox(od,text[1:],f_small)
    y=img.height//2-max(th_big,th_sm)//2
    cw,_=tbbox(od,text[0],f_big)
    od.text((x,y),text[0],font=f_big,fill=(255,220,0,255))
    od.text((x+cw,y+(th_big-th_sm)),text[1:],font=f_small,fill=(255,255,255,220))
    return Image.alpha_composite(img,ov)

def effect_drop_cap(bg, text, size):
    """Large drop-cap first letter with rest of text beside it."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    fc=gf(size*2); fr=gf(size)
    cw,ch=tbbox(od,text[0],fc); rw,rh=tbbox(od,text[1:],fr)
    total_w=cw+10+rw; x=(img.width-total_w)//2; y=(img.height-ch)//2
    od.text((x,y),text[0],font=fc,fill=(255,220,50,255))
    od.text((x+cw+10,y+ch-rh),text[1:],font=fr,fill=(255,255,255,230))
    return Image.alpha_composite(img,ov)

