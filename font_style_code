def effect_wave_distortion(bg, text, size):
    img=bg.copy(); tmp=Image.new("RGBA",img.size,(0,0,0,0)); d=ImageDraw.Draw(tmp)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f); x,y=center_xy(img,tw,th)
    d.text((x,y),text,font=f,fill=(255,255,255,255))
    arr=pil_to_np(tmp)
    out=np.zeros_like(arr)
    for row in range(arr.shape[0]):
        offset=int(8*math.sin(row*0.15))
        shifted=np.roll(arr[row],offset,axis=0)
        out[row]=shifted
    return Image.alpha_composite(img,np_to_pil(out))

def effect_sinusoidal_warp(bg, text, size):
    img=bg.copy(); tmp=Image.new("RGBA",img.size,(0,0,0,0)); d=ImageDraw.Draw(tmp)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f); x,y=center_xy(img,tw,th)
    d.text((x,y),text,font=f,fill=(255,120,200,255))
    arr=pil_to_np(tmp); out=np.zeros_like(arr)
    for col in range(arr.shape[1]):
        offset=int(6*math.sin(col*0.1))
        shifted=np.roll(arr[:,col],offset,axis=0)
        out[:,col]=shifted
    return Image.alpha_composite(img,np_to_pil(out))

