    d2=ImageDraw.Draw(img); f2,_=fit(d2,text,img.width-40,size)
    tw,th=tbbox(d2,text,f2); x,y=center_xy(img,tw,th)
    d2.text((x,y),text,font=f2,fill=(220,220,220,255)); return img

def effect_blood_drip(bg, text, size):
