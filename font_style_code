def effect_vhs_tape(bg, text, size):
    img=bg.copy(); arr=pil_to_np(img)
    for row in range(0,img.height,3): arr[row,:,0]=np.clip(arr[row,:,0]+30,0,255)
    for row in range(1,img.height,3): arr[row,:,2]=np.clip(arr[row,:,2]+20,0,255)
    random.seed(55)
    for _ in range(8):
        row=random.randint(0,img.height-2); shift=random.randint(-20,20)
        arr[row]=np.roll(arr[row],shift,axis=0)
    img=np_to_pil(arr).convert("RGBA")
    tmp,f,x,y,tw,th=text_layer(img,text,size,fill=(255,240,240,255))
    return Image.alpha_composite(img,tmp)

def effect_hologram(bg, text, size):
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    f,_=fit(od,text,img.width-40,size); tw,th=tbbox(od,text,f); x,y=center_xy(img,tw,th)
    for i in range(0,img.height,4):
        a=int(15+10*math.sin(i*0.3)); od.line([(0,i),(img.width,i)],fill=(0,200,255,a))
    for r in range(6,0,-2):
        od.text((x-r//2,y-r//2),text,font=f,fill=(0,200,255,int(40*(1-r/6))))
    od.text((x,y),text,font=f,fill=(180,255,255,220))
    return Image.alpha_composite(img,ov.filter(ImageFilter.GaussianBlur(1)))

def effect_reality_tear(bg, text, size):
    img=bg.copy()
    shifted=ImageChops.offset(img,0,40)
    shifted_arr=pil_to_np(shifted); orig_arr=pil_to_np(img)
    f,_=fit(ImageDraw.Draw(img),text,img.width-40,size)
    d=ImageDraw.Draw(img); tw,th=tbbox(d,text,f); x,y=center_xy(img,tw,th)
    mask=np.zeros((img.height,img.width),dtype=np.float32)
    for row in range(y-20,y+th+20):
        if 0<=row<img.height:
            noise=np.random.rand(img.width)*0.8+0.2; mask[row]=noise
    blend=orig_arr*(1-mask[:,:,None])+shifted_arr*(mask[:,:,None])
    result=np_to_pil(blend).convert("RGBA")
    tmp,_,_,_,_,_=text_layer(result,text,size,fill=(255,80,200,255))
    return Image.alpha_composite(result,tmp)

