def effect_scanline_glitch(bg, text, size):
    img=bg.copy(); tmp,f,x,y,tw,th=text_layer(img,text,size,fill=(0,255,200,255))
    img=Image.alpha_composite(img,tmp)
    arr=pil_to_np(img)
    for row in range(0,img.height,4):
        arr[row]=arr[row]*0.4
    for _ in range(6):
        row=random.randint(0,img.height-3)
        shift=random.randint(-15,15)
        arr[row]=np.roll(arr[row],shift,axis=0)
    return np_to_pil(arr).convert("RGBA")

def effect_pixel_scatter(bg, text, size):
    img=bg.copy(); tmp=Image.new("RGBA",img.size,(0,0,0,0)); d=ImageDraw.Draw(tmp)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f); x,y=center_xy(img,tw,th)
    d.text((x,y),text,font=f,fill=(255,255,255,255))
    arr=pil_to_np(tmp)
    mask=arr[:,:,3]>10
    coords=np.argwhere(mask)
    out=np.zeros_like(arr)
    random.seed(7)
    for (r,c) in coords:
        nr=r+random.randint(-8,8); nc=c+random.randint(-8,8)
        if 0<=nr<arr.shape[0] and 0<=nc<arr.shape[1]:
            out[nr,nc]=arr[r,c]
    return Image.alpha_composite(img,np_to_pil(out))

def effect_fragment_explosion(bg, text, size):
    img=bg.copy(); tmp,f,x,y,tw,th=text_layer(img,text,size,fill=(255,255,255,255))
    arr=pil_to_np(tmp); out=np.zeros_like(arr)
    cx2,cy2=x+tw//2,y+th//2; random.seed(3)
    for r in range(arr.shape[0]):
        for c in range(arr.shape[1]):
            if arr[r,c,3]>10:
                dx=c-cx2; dy=r-cy2; dist=math.sqrt(dx*dx+dy*dy)+1
                nr=r+int(dy/dist*random.randint(2,12))
                nc=c+int(dx/dist*random.randint(2,12))
                if 0<=nr<arr.shape[0] and 0<=nc<arr.shape[1]:
                    out[nr,nc]=arr[r,c]
