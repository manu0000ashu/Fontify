def effect_centered(bg, text, size):
    img=bg.copy(); d=ImageDraw.Draw(img)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f)
    x,y=center_xy(img,tw,th)
    d.text((x+3,y+3),text,font=f,fill=(0,0,0,180))
    d.text((x,y),text,font=f,fill=(255,255,255,255)); return img

def effect_bottom_band(bg, text, size):
    img=bg.copy(); d=ImageDraw.Draw(img)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f)
    bh=th+40; ov=Image.new("RGBA",img.size,(0,0,0,0))
    ImageDraw.Draw(ov).rectangle([0,img.height-bh,img.width,img.height],fill=(0,0,0,165))
    img=Image.alpha_composite(img,ov); d=ImageDraw.Draw(img)
    d.text(((img.width-tw)//2, img.height-bh+(bh-th)//2),text,font=f,fill=(255,255,255,255)); return img

def effect_top_overlay(bg, text, size):
    img=bg.copy(); d=ImageDraw.Draw(img)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f)
    bh=th+50; ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    for i in range(bh): od.line([(0,i),(img.width,i)],fill=(0,0,0,int(185*(1-i/bh))))
    img=Image.alpha_composite(img,ov); d=ImageDraw.Draw(img)
    d.text(((img.width-tw)//2,(bh-th)//2),text,font=f,fill=(255,255,255,255)); return img

