# ── CORE HELPERS ──────────────────────────────────────────────────
def load_image(path) -> Image.Image:
    return Image.open(str(path)).convert("RGBA")

def save(img: Image.Image, path: str):
    img.convert("RGB").save(path, quality=92)

def gf(size: int) -> ImageFont.FreeTypeFont:
    return ImageFont.truetype(FONT_PATH, size)

def tbbox(draw, text, font):
    bb = draw.textbbox((0, 0), text, font=font)
    return bb[2]-bb[0], bb[3]-bb[1]

def fit(draw, text, max_w, size, min_s=16):
    s = size
    while s >= min_s:
        f = gf(s)
        w, _ = tbbox(draw, text, f)
        if w <= max_w: return f, s
        s -= 3
    return gf(min_s), min_s

def center_xy(img, tw, th):
    return (img.width-tw)//2, (img.height-th)//2

def text_layer(img, text, size, fill=(255,255,255,255), shadow=None):
    """Render text centred on a transparent layer same size as img."""
    tmp = Image.new("RGBA", img.size, (0,0,0,0))
    d   = ImageDraw.Draw(tmp)
    f, _ = fit(d, text, img.width-40, size)
    tw, th = tbbox(d, text, f)
    x, y = center_xy(img, tw, th)
    if shadow:
        d.text((x+shadow[0], y+shadow[1]), text, font=f, fill=shadow[2])
    d.text((x, y), text, font=f, fill=fill)
    return tmp, f, x, y, tw, th

def render_chars(img, text, size, color_fn):
    """Render each character individually with color_fn(i, char) -> RGBA."""
    tmp = Image.new("RGBA", img.size, (0,0,0,0))
    d   = ImageDraw.Draw(tmp)
    f, _ = fit(d, text, img.width-40, size)
    full_w, full_h = tbbox(d, text, f)
    cx = (img.width - full_w)//2
    cy = (img.height - full_h)//2
    x  = cx
    for i, ch in enumerate(text):
        cw, ch2 = tbbox(d, ch, f)
        d.text((x, cy), ch, font=f, fill=color_fn(i, ch))
        x += cw
    return tmp

def np_to_pil(arr):
    arr = np.clip(arr, 0, 255).astype(np.uint8)
    return Image.fromarray(arr)

def pil_to_np(img):
    return np.array(img).astype(np.float32)


