    img=Image.alpha_composite(img,tmp); d=ImageDraw.Draw(img); random.seed(44)
    for _ in range(len(text)+5):
        dx=random.randint(x,x+tw); drip=random.randint(5,25); w=random.randint(1,3)
        for dj in range(drip):
            t=dj/drip; r=max(1,int(w*(1-t)))
            d.ellipse([dx-r,y+th+dj,dx+r,y+th+dj+2],fill=(180,230,255,int(200*(1-t))))
    return img


