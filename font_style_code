def effect_vertical_stack(bg, text, size):
    """Letters stacked vertically down the centre."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    f=gf(size); ch_h=tbbox(od,"A",f)[1]+4
    total_h=ch_h*len(text); y=(img.height-total_h)//2
    for ch in text:
        cw,_=tbbox(od,ch,f); x=(img.width-cw)//2
        od.text((x+2,y+2),ch,font=f,fill=(0,0,0,160)); od.text((x,y),ch,font=f,fill=(255,255,255,255))
        y+=ch_h
    return Image.alpha_composite(img,ov)

def effect_diagonal_sweep(bg, text, size):
    """Text swept diagonally across the whole image."""
    img=bg.copy(); tmp=Image.new("RGBA",(img.width*2,img.height*2),(0,0,0,0)); td=ImageDraw.Draw(tmp)
    f,_=fit(td,text,img.width,size); tw,th=tbbox(td,text,f)
    cx,cy=tmp.width//2,tmp.height//2
    td.text((cx-tw//2+2,cy-th//2+2),text,font=f,fill=(0,0,0,150))
    td.text((cx-tw//2,cy-th//2),text,font=f,fill=(255,255,100,230))
    rot=tmp.rotate(-30,resample=Image.BICUBIC)
    ox=(rot.width-img.width)//2; oy=(rot.height-img.height)//2
    return Image.alpha_composite(img,rot.crop((ox,oy,ox+img.width,oy+img.height)))

def effect_curved_arc(bg, text, size):
    """Text curved along a top arc."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    f=gf(size); r=img.width*0.55; cx=img.width//2; cy=img.height+int(r*0.2)
    angle_span=math.radians(60); start=-math.pi/2-angle_span/2
    for i,ch in enumerate(text):
        t=i/(max(len(text)-1,1))
        a=start+t*angle_span
        x=cx+r*math.cos(a); y=cy+r*math.sin(a)
        cw,ch2=tbbox(od,ch,f)
        tmp2=Image.new("RGBA",img.size,(0,0,0,0)); ImageDraw.Draw(tmp2).text((img.width//2-cw//2,img.height//2-ch2//2),ch,font=f,fill=(255,255,255,255))
        deg=math.degrees(a)+90
        rot=tmp2.rotate(-deg,resample=Image.BICUBIC,center=(img.width//2,img.height//2))
        # Translate
        tx=int(x-img.width//2); ty=int(y-img.height//2)
        shifted=Image.new("RGBA",img.size,(0,0,0,0))
        shifted.paste(rot,(tx,ty))
        ov=Image.alpha_composite(ov,shifted)
    return Image.alpha_composite(img,ov)

def effect_circular_ring(bg, text, size):
    """Text arranged in a full circle."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0))
    f=gf(max(16,size//2)); cx=img.width//2; cy=img.height//2; r=min(cx,cy)-30
    for i,ch in enumerate(text):
        a=2*math.pi*i/len(text)-math.pi/2
        x=int(cx+r*math.cos(a)); y=int(cy+r*math.sin(a))
        tmp2=Image.new("RGBA",img.size,(0,0,0,0))
        d2=ImageDraw.Draw(tmp2); cw,ch2=tbbox(d2,ch,f)
        d2.text((cx-cw//2,cy-ch2//2-r),ch,font=f,fill=(255,255,255,255))
        ov=Image.alpha_composite(ov,tmp2.rotate(-math.degrees(a),resample=Image.BICUBIC,center=(cx,cy)))
    return Image.alpha_composite(img,ov)

def effect_spiral(bg, text, size):
    """Each letter placed along an outward spiral."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    cx=img.width//2; cy=img.height//2
    for i,ch in enumerate(text):
        t=i/max(len(text),1); a=t*4*math.pi; r=t*min(cx,cy)*0.85
        x=int(cx+r*math.cos(a)); y=int(cy+r*math.sin(a))
        fs=max(12,int(size*(0.5+0.5*t))); f=gf(fs); cw,ch2=tbbox(od,ch,f)
        col=(int(255*t),int(200*(1-t)),255,220)
        od.text((x-cw//2,y-ch2//2),ch,font=f,fill=col)
    return Image.alpha_composite(img,ov)

def effect_perspective_warp(bg, text, size):
    """Simulate perspective by shrinking top of text (trapezoid warp)."""
    img=bg.copy()
    tmp=Image.new("RGBA",img.size,(0,0,0,0)); td=ImageDraw.Draw(tmp)
    f,_=fit(td,text,img.width-40,size); tw,th=tbbox(td,text,f); x,y=center_xy(img,tw,th)
    td.text((x,y),text,font=f,fill=(255,255,255,255))
    arr=np.array(tmp)  # uint8 (H,W,4)
    out=np.zeros_like(arr)
    for row in range(th):
        t=row/max(th-1,1); scale=0.3+0.7*t; new_w=int(tw*scale)
        if new_w<1: continue
        src=arr[y+row, x:x+tw]           # (tw, 4) uint8
        if src.shape[0]==0: continue
        row_img=Image.fromarray(src.reshape(1,-1,4),"RGBA").resize((new_w,1),Image.BILINEAR)
        strip=np.array(row_img)[0]        # (new_w, 4)
        ox=x+(tw-new_w)//2
        end=min(ox+new_w, out.shape[1])
        cols=end-ox
        if cols>0:
            out[y+row, ox:end] = strip[:cols]
    return Image.alpha_composite(img, Image.fromarray(out,"RGBA"))

def effect_vanishing_stretch(bg, text, size):
    """Text that appears to stretch toward a vanishing point."""
    img=bg.copy(); ov=Image.new("RGBA",img.size,(0,0,0,0)); od=ImageDraw.Draw(ov)
    steps=8
    for i in range(steps):
        t=i/steps; s=max(10,int(size*(0.2+0.8*t))); f=gf(s)
        tw,th=tbbox(od,text,f); x=(img.width-tw)//2; y=img.height//2+int((i-steps//2)*(th+2))
        a=int(50+200*t); od.text((x,y),text,font=f,fill=(255,255,255,a))
    return Image.alpha_composite(img,ov)

def effect_skewed_parallelogram(bg, text, size):
    """Text on a skewed parallelogram banner."""
    img=bg.copy()
    f,_=fit(ImageDraw.Draw(img),text,img.width-40,size); d2=ImageDraw.Draw(img)
    tw,th=tbbox(d2,text,f); pad=20; bh=th+pad*2; cy=img.height//2
    skew=40; pts=[(skew,cy-bh//2),(img.width-skew+skew,cy-bh//2),(img.width-skew,cy+bh//2),(0,cy+bh//2)]
    ov=Image.new("RGBA",img.size,(0,0,0,0)); ImageDraw.Draw(ov).polygon(pts,fill=(30,30,180,200))
    img=Image.alpha_composite(img,ov); ImageDraw.Draw(img).text(((img.width-tw)//2,cy-th//2),text,font=f,fill=(255,255,255,255))
    return img


