def effect_water_reflection(bg, text, size):
    """Text + its wavy reflection below."""
    img=bg.copy(); tmp=Image.new("RGBA",img.size,(0,0,0,0)); d=ImageDraw.Draw(tmp)
    f,_=fit(d,text,img.width-40,size); tw,th=tbbox(d,text,f); x,y=center_xy(img,tw,th)
    y=img.height//3
    d.text((x,y),text,font=f,fill=(255,255,255,255))
    # Reflection: flip + wave distort + fade
    ref=Image.new("RGBA",img.size,(0,0,0,0)); rd=ImageDraw.Draw(ref)
    rd.text((x,y),text,font=f,fill=(200,230,255,255))
    ref_flip=ref.transpose(Image.FLIP_TOP_BOTTOM)
    arr=pil_to_np(ref_flip); out=np.zeros_like(arr)
    for col in range(arr.shape[1]):
        wave=int(4*math.sin(col*0.12))
        shifted=np.roll(arr[:,col],wave,axis=0)
        out[:,col]=shifted
    # Fade bottom
    for row in range(out.shape[0]):
        t=row/out.shape[0]; out[row,:,3]*=(1-t*0.9)
    ref2=np_to_pil(out)
    result=Image.alpha_composite(img,tmp); result=Image.alpha_composite(result,ref2)
    return result

