# ── GENERATE ONE SHOWCASE ─────────────────────────────────────────
def generate_showcase(font_path, layout_name=None, palette=None, seed=None):
    if seed is not None: random.seed(seed); np.random.seed(seed%2**31)
    fp    = str(font_path)
    name, fn = random.choice(LAYOUTS) if layout_name is None else next(x for x in LAYOUTS if x[0]==layout_name)
    pal   = palette or random.choice(PALETTES)

    try:
        img = fn(fp, pal, CARD_W, CARD_H)
    except Exception as e:
        # Fallback: single letter
        img = layout_single_letter_hero(fp, pal, CARD_W, CARD_H)
        print(f"   ⚠ '{name}' failed ({e}), used fallback")

    # Subtle vignette on all cards
    img = vignette(img, 0.35)
    return img, name, pal


