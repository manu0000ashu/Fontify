# ── CORE HELPERS ─────────────────────────────────────────────────
def lf(path, size):
    try: return ImageFont.truetype(str(path), max(1,size))
    except: return ImageFont.load_default()

def bb(draw, text, font):
    r = draw.textbbox((0,0), text, font=font)
    return r[2]-r[0], r[3]-r[1]

def cxy(W,H,tw,th): return (W-tw)//2, (H-th)//2

def noise(img, s=6):
    a = np.array(img).astype(np.int16)
    a = np.clip(a + np.random.randint(-s,s,a.shape), 0, 255).astype(np.uint8)
    return Image.fromarray(a)

def grain_overlay(img, strength=0.04):
    arr = np.array(img).astype(np.float32)
    g = np.random.randn(*arr.shape[:2]) * 255 * strength
    arr[:,:,0] = np.clip(arr[:,:,0]+g, 0, 255)
    arr[:,:,1] = np.clip(arr[:,:,1]+g, 0, 255)
    arr[:,:,2] = np.clip(arr[:,:,2]+g, 0, 255)
    return Image.fromarray(arr.astype(np.uint8))

def vignette(img, strength=0.5):
    W,H = img.size
    arr = np.array(img).astype(np.float32)
    cx,cy = W/2, H/2
    Y,X = np.ogrid[:H,:W]
    dist = np.sqrt(((X-cx)/cx)**2 + ((Y-cy)/cy)**2)
    mask = 1 - np.clip(dist*strength, 0, 1)*0.6
    for c in range(3): arr[:,:,c] *= mask
    return Image.fromarray(np.clip(arr,0,255).astype(np.uint8))

def scanlines(img, gap=4, alpha=30):
    W,H = img.size
    ov = Image.new("RGBA",(W,H),(0,0,0,0))
    d = ImageDraw.Draw(ov)
    for y in range(0,H,gap): d.line([(0,y),(W,y)],fill=(0,0,0,alpha))
    return Image.alpha_composite(img.convert("RGBA"),ov).convert("RGB")

def halftone_circle(draw, cx, cy, r, col, dots=8):
    for i in range(dots):
        a = 2*math.pi*i/dots
        x,y = cx+r*math.cos(a), cy+r*math.sin(a)
        dr = max(2, r//6)
        draw.ellipse([x-dr,y-dr,x+dr,y+dr], fill=col)

def draw_rule(draw,x1,y1,x2,y2,col,w=1):
    draw.line([(x1,y1),(x2,y2)],fill=col,width=w)

def font_name(path): return Path(path).stem.replace("-"," ").replace("_"," ")

def fit_to_width(fp, text, max_w, start_size=400, min_size=12):
    tmp = Image.new("RGB",(max_w*2,400))
    d = ImageDraw.Draw(tmp)
    s = start_size
    while s >= min_size:
        f = lf(fp,s); w,_ = bb(d,text,f)
        if w <= max_w: return f, s
        s -= max(1, s//20)
    return lf(fp,min_size), min_size


