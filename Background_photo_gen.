    """Vertical column of single letters — newspaper column energy."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    # Left: massive letter column
    letters = list(ALPHABET_STR[:12])
    col_size = H//12 - 4
    f = lf(fp, col_size)
    for i,ch in enumerate(letters):
        y = i*(col_size+4)+10
        col = pal["a1"] if i%4==0 else pal["fg"]
        d.text((30, y), ch, font=f, fill=col)
    # Vertical rule
    draw_rule(d, int(W*0.22), 0, int(W*0.22), H, pal["a1"], 3)
    # Right: giant single letter
    ch_big = random.choice(list("ABCGMNRST"))
    f_big, _ = fit_to_width(fp, ch_big, int(W*0.70), 700)
    tw,th = bb(d,ch_big,f_big)
    d.text((int(W*0.24), (H-th)//2), ch_big, font=f_big, fill=pal["fg"])
    # Ghost behind
    d.text((int(W*0.24)+12, (H-th)//2+12), ch_big, font=f_big, fill=(*pal["a1"][:3],18))
    return grain_overlay(img, 0.03)

def layout_book_cover(fp, pal, W, H):
    """Clean book cover composition — Frontier/Audubon aesthetic."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    # Top thick bar
    bar_h = int(H*0.12)
    d.rectangle([0,0,W,bar_h], fill=pal["a1"])
    # Bottom bar
    d.rectangle([0,H-bar_h,W,H], fill=pal["dim"])
    # Central letterform — fits within safe zone
    ch = random.choice(list("ABCDEFGMNPRSTW"))
    f, sz = fit_to_width(fp, ch, int(W*0.5), 600)
    tw,th = bb(d,ch,f)
    cx = int(W*0.62); cy = H//2
    # Shadow
    d.text((cx-tw//2+8,cy-th//2+8), ch, font=f, fill=(*pal["dim"][:3],120))
    d.text((cx-tw//2, cy-th//2), ch, font=f, fill=pal["fg"])
    # Left: vertical letters small
    f_sm = lf(fp, 22)
    for i,c2 in enumerate(ALPHABET_STR[:16]):
        d.text((28, bar_h+20+i*((H-bar_h*2-40)//16)), c2, font=f_sm, fill=pal["fg"])
    # Thin line separating left strip
    draw_rule(d, 60, bar_h+10, 60, H-bar_h-10, pal["a2"], 1)
    return grain_overlay(img, 0.04)

def layout_halftone_ghost(fp, pal, W, H):
    """Giant ghost letter with halftone dot pattern overlay."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    ch = random.choice(list("ABCDEFGHJKMNOPQRST"))
    # Ghost letter super faint
    f_ghost, _ = fit_to_width(fp, ch, int(W*0.95), 800)
    tg,thg = bb(d,ch,f_ghost)
    d.text(((W-tg)//2,(H-thg)//2), ch, font=f_ghost, fill=(*pal["fg"][:3],20))
    # Halftone dots following letter silhouette
    f_mask, _ = fit_to_width(fp, ch, int(W*0.82), 700)
    tm,thm = bb(d,ch,f_mask)
    # Create letter mask
    mask_img = Image.new("L",(W,H),0)
    ImageDraw.Draw(mask_img).text(((W-tm)//2,(H-thm)//2), ch, font=f_mask, fill=255)
    mask_arr = np.array(mask_img)
    # Draw dots where mask is filled
    dot_gap = 22
    for y in range(0,H,dot_gap):
        for x in range(0,W,dot_gap):
            if mask_arr[min(y,H-1),min(x,W-1)] > 80:
                # size based on distance from edge of letter
                sz = random.randint(3,10)
                col = pal["a1"] if random.random()<0.2 else pal["fg"]
                d.ellipse([x-sz,y-sz,x+sz,y+sz], fill=col)
    return grain_overlay(img, 0.03)

def layout_vhs_horror(fp, pal, W, H):
    """VHS/horror movie poster energy — like Videodrome."""
    bg_pal = {"bg":(5,5,8),"fg":(255,255,255),"a1":(255,30,30),"a2":(0,200,100),"dim":(30,30,35)}
    img = Image.new("RGB",(W,H), bg_pal["bg"])
    d = ImageDraw.Draw(img)
    word = random.choice(["FORM","BOLD","TYPE","EDIT","NEUE","GRSK"])
    # Scanline texture bg
    for y in range(0,H,3): d.line([(0,y),(W,y)],fill=(15,15,18))
    # RGB glitch: draw word 3 times offset
    f, sz = fit_to_width(fp, word, W-60, 500)
    tw,th = bb(d,word,f); x,y = cxy(W,H,tw,th)
    for off,col in [(-4,(255,0,0,80)),(0,(0,255,100,80)),(4,(0,100,255,80))]:
        tmp = Image.new("RGBA",(W,H),(0,0,0,0))
        ImageDraw.Draw(tmp).text((x+off,y),word,font=f,fill=col)
        img = Image.alpha_composite(img.convert("RGBA"),tmp).convert("RGB")
    d = ImageDraw.Draw(img)
    d.text((x,y), word, font=f, fill=bg_pal["fg"])
    # Glitch lines
    for _ in range(6):
        gy = random.randint(0,H); gw = random.randint(50,200)
        gx = random.randint(0,W-gw)
        d.rectangle([gx,gy,gx+gw,gy+random.randint(1,3)], fill=bg_pal["a1"])
    img = grain_overlay(img, 0.06)
    return img

def layout_swiss_grid(fp, pal, W, H):
    """Swiss International Typographic Style — pure grid geometry."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    # Grid
    cols, rows = 8, 5
    cw, rh = W//cols, H//rows
    # Filled cells
    fill_cells = random.sample([(r,c) for r in range(rows) for c in range(cols)], 6)
    for (r,c) in fill_cells:
        col = pal["a1"] if random.random()<0.4 else pal["dim"]
        d.rectangle([c*cw+1,r*rh+1,(c+1)*cw-1,(r+1)*rh-1], fill=col)
    # Letters in remaining cells
    f_cell = lf(fp, int(min(cw,rh)*0.65))
    used = set(fill_cells)
    letter_cells = random.sample([(r,c) for r in range(rows) for c in range(cols) if (r,c) not in used], 12)
    for i,(r,c) in enumerate(letter_cells):
        ch = ALPHABET_STR[i%26]
        cw2,ch2 = bb(d,ch,f_cell)
        cx = c*cw+(cw-cw2)//2; cy = r*rh+(rh-ch2)//2
        col = pal["fg"] if (r,c) not in fill_cells else pal["bg"]
        d.text((cx,cy), ch, font=f_cell, fill=col)
    # Hairlines
    for c in range(cols+1): draw_rule(d,c*cw,0,c*cw,H,(*pal["dim"][:3],80),1)
    for r in range(rows+1): draw_rule(d,0,r*rh,W,r*rh,(*pal["dim"][:3],80),1)
    return grain_overlay(img, 0.025)

def layout_ink_bleed(fp, pal, W, H):
    """Oversized letter bleeds off edges — raw ink energy."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    ch = random.choice(list("ABCEFGHJKMNPQRSTW"))
    # Bleed off edges — letter bigger than canvas
    sz = int(H*1.4)
    f = lf(fp, sz)
    tw,th = bb(d,ch,f)
    # Offset to bleed on one side
    offsets = [(-tw//3,-th//4), (-tw//2,0), (0,-th//3), (W//4-tw//2,-th//4)]
    ox,oy = random.choice(offsets)
    # Ink shadow
    d.text((ox+12,oy+12), ch, font=f, fill=(*pal["a1"][:3],25))
    d.text((ox,oy), ch, font=f, fill=pal["fg"])
    # Corner accent
    d.rectangle([0,0,W,8], fill=pal["a1"])
    return grain_overlay(img, 0.04)

def layout_weight_ladder(fp, pal, W, H):
    """Same letter at ascending sizes — staircase composition."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    ch = random.choice(list("ABCGHMNORSTW"))
    sizes = [16,22,30,42,58,80,110,150,200,270]
    x_start = 30; y_start = H-30
    x = x_start
    for i,sz in enumerate(sizes):
        f = lf(fp,sz); tw,th = bb(d,ch,f)
        y = y_start - th
        t = i/len(sizes)
        r = int(pal["dim"][0]*(1-t)+pal["fg"][0]*t)
        g = int(pal["dim"][1]*(1-t)+pal["fg"][1]*t)
        b = int(pal["dim"][2]*(1-t)+pal["fg"][2]*t)
        col = pal["a1"] if i==len(sizes)-1 else (r,g,b)
        d.text((x,y), ch, font=f, fill=col)
        x += tw+int(sz*0.08)
        if x > W-50: break
    draw_rule(d, 30, H-36, min(x,W-20), H-36, pal["a2"], 2)
    return grain_overlay(img, 0.03)

def layout_negative_space(fp, pal, W, H):
    """Inverted — dark letter punched from white field."""
    img = Image.new("RGB",(W,H), pal["fg"])
    d = ImageDraw.Draw(img)
    ch = random.choice(list("ABCDEFGHJKMNPQRST"))
    f, sz = fit_to_width(fp, ch, int(W*0.82), 700)
    tw,th = bb(d,ch,f)
    # Letter in bg colour = punched out
    d.text(((W-tw)//2,(H-th)//2), ch, font=f, fill=pal["bg"])
    # Thin border inside letter as accent
    for r in range(1,4):
        tmp = Image.new("RGBA",(W,H),(0,0,0,0))
        ImageDraw.Draw(tmp).text(((W-tw)//2,(H-th)//2), ch, font=f, fill=(*pal["a1"][:3],int(60/r)))
        # Erode to get inner ring — just offset
        for ox,oy in [(r,0),(-r,0),(0,r),(0,-r)]:
            tmp2 = Image.new("RGBA",(W,H),(0,0,0,0))
            ImageDraw.Draw(tmp2).text(((W-tw)//2+ox,(H-th)//2+oy), ch, font=f, fill=(*pal["bg"][:3],255))
            img.paste(Image.alpha_composite(img.convert("RGBA"),tmp2).convert("RGB"))
    draw_rule(ImageDraw.Draw(img), 0,0,W,0,pal["a1"],6)
    draw_rule(ImageDraw.Draw(img), 0,H-1,W,H-1,pal["a1"],6)
    return grain_overlay(img, 0.025)

def layout_constructivist(fp, pal, W, H):
    """Constructivist — diagonal geometry + bold letterforms. EAT SLEEP BRAND energy."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    # Bold diagonal red rectangle
    pts = [(0,H//3),(W//2,0),(W,H//4),(W//2,H)]
    d.polygon(pts, fill=pal["a1"])
    # Two-tone geometry
    d.polygon([(0,H*2//3),(W//4,H//2),(W//3,H),(0,H)], fill=pal["dim"])
    # Letters
    word = random.choice(PUNCHY_WORDS)
    f, sz = fit_to_width(fp, word, int(W*0.75), 500)
    tw,th = bb(d,word,f)
    x,y = cxy(W,H,tw,th)
    # Shadow
    d.text((x+6,y+6), word, font=f, fill=(*pal["bg"][:3],80))
    d.text((x,y), word, font=f, fill=pal["fg"])
    return grain_overlay(img, 0.04)


