def layout_single_letter_hero(fp, pal, W, H):
    """One massive letter fills the entire card — pure letterform study."""
    img = Image.new("RGB",(W,H), pal["bg"])
    ch = random.choice(list("ABCDEFGHJKMNPQRSTUVWXYZ"))
    f, sz = fit_to_width(fp, ch, int(W*0.92), 800)
    d = ImageDraw.Draw(img)
    tw,th = bb(d,ch,f)
    x,y = cxy(W,H,tw,th)
    # Ghost echo
    echo_f = lf(fp, int(sz*1.05))
    etw,eth = bb(d,ch,echo_f)
    ex,ey = cxy(W,H,etw,eth)
    d.text((ex+6,ey+6), ch, font=echo_f, fill=(*pal["a1"][:3],30))
    # Main letter
    d.text((x,y), ch, font=f, fill=pal["fg"])
    # Thin accent line
    draw_rule(d, 0, H-6, W, H-6, pal["a1"], 4)
    img = grain_overlay(img)
    return img

def layout_two_letter_contrast(fp, pal, W, H):
    """Uppercase vs lowercase of same letter — dramatic size contrast."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    pair = random.choice(HERO_PAIRS)
    upper, lower = pair[0], pair[1]
    # Big uppercase left
    fu, su = fit_to_width(fp, upper, int(W*0.52), 700)
    twu,thu = bb(d,upper,fu)
    d.text((int(W*0.04), (H-thu)//2), upper, font=fu, fill=pal["fg"])
    # Small lowercase right, vertically centred
    fl, sl = fit_to_width(fp, lower, int(W*0.38), 500)
    twl,thl = bb(d,lower,fl)
    d.text((int(W*0.54), (H-thl)//2), lower, font=fl, fill=pal["a1"])
    # Vertical divider
    draw_rule(d, W//2, 40, W//2, H-40, pal["dim"], 2)
    img = grain_overlay(img, 0.03)
    return img

def layout_alphabet_arc(fp, pal, W, H):
    """Letters arranged along a sweeping arc."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    letters = ALPHABET_STR[:18]
    f = lf(fp, 52)
    cx,cy = W//2, H+120
    r = H+80
    span = math.radians(58)
    start = -math.pi/2 - span/2
    for i,ch in enumerate(letters):
        t = i/(len(letters)-1)
        a = start + t*span
        x = int(cx + r*math.cos(a))
        y = int(cy + r*math.sin(a))
        cw,ch2 = bb(d,ch,f)
        col = pal["fg"] if i%3!=1 else pal["a1"]
        tmp2 = Image.new("RGBA",(W,H),(0,0,0,0))
        ImageDraw.Draw(tmp2).text((W//2-cw//2, H//2-ch2//2-r+20), ch, font=f, fill=(*col,230))
        rot = tmp2.rotate(-math.degrees(a), resample=Image.BICUBIC, center=(W//2,H//2))
        img.paste(Image.alpha_composite(img.convert("RGBA"),rot).convert("RGB"))
    img = grain_overlay(img)
    return img

def layout_poster_fill(fp, pal, W, H):
    """Text bleeds edge to edge — full bleed poster energy like 'Twilight of Briareus'."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    word = random.choice(PUNCHY_WORDS + ["NEUE","GRSK","TYPE","BOLD","FORM","SANS"])
    # Fill width exactly
    f, sz = fit_to_width(fp, word, W-20, 600)
    tw,th = bb(d,word,f)
    # Stack 3 times at slight offsets for depth
    offsets = [(8,8,(*pal["a1"][:3],15)), (3,3,(*pal["a1"][:3],25)), (0,0,(*pal["fg"][:3],255))]
    y = (H-th)//2
    for ox,oy,col in offsets:
        d.text(((W-tw)//2+ox, y+oy), word, font=f, fill=col)
    # Bold horizontal rules
    draw_rule(d, 0, y-16, W, y-16, pal["a1"], 5)
    draw_rule(d, 0, y+th+12, W, y+th+12, pal["a1"], 5)
    img = grain_overlay(img, 0.05)
    return img

def layout_grid_letters(fp, pal, W, H):
    """Letters in a tight grid — like a stamp sheet or periodic table."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    cols, rows = 6, 4
    cw, rh = W//cols, H//rows
    letters = list(ALPHABET_STR)
    random.shuffle(letters)
    f = lf(fp, int(min(cw,rh)*0.55))
    for row in range(rows):
        for col in range(cols):
            idx = row*cols+col
            if idx >= len(letters): break
            ch = letters[idx]
            x = col*cw; y = row*rh
            # Alternating background tile
            if (row+col)%2==0:
                d.rectangle([x,y,x+cw-2,y+rh-2], fill=pal["dim"])
            tw2,th2 = bb(d,ch,f)
            col_c = pal["a1"] if (row+col)%3==0 else pal["fg"]
            d.text((x+(cw-tw2)//2, y+(rh-th2)//2), ch, font=f, fill=col_c)
    img = grain_overlay(img, 0.02)
    return img

def layout_split_color_letter(fp, pal, W, H):
    """One giant letter split diagonally — two colours."""
    img = Image.new("RGB",(W,H), pal["bg"])
    ch = random.choice(list("ABCDEFGHJKMNPQRSTVW"))
    f, sz = fit_to_width(fp, ch, int(W*0.85), 700)
    d = ImageDraw.Draw(img)
    tw,th = bb(d,ch,f)
    x,y = cxy(W,H,tw,th)
    # Draw letter in fg
    layer1 = Image.new("RGB",(W,H), pal["bg"])
    d1 = ImageDraw.Draw(layer1); d1.text((x,y), ch, font=f, fill=pal["fg"])
    # Draw letter in accent
    layer2 = Image.new("RGB",(W,H), pal["bg"])
    d2 = ImageDraw.Draw(layer2); d2.text((x,y), ch, font=f, fill=pal["a1"])
    # Diagonal split mask
    mask = Image.new("L",(W,H),0)
    md = ImageDraw.Draw(mask)
    md.polygon([(0,0),(W,0),(W,H)], fill=255)
    result = Image.composite(layer2, layer1, mask)
    # Diagonal line
    draw_rule(ImageDraw.Draw(result), 0,0, W,H, pal["a2"], 3)
    return grain_overlay(result)

def layout_number_mono(fp, pal, W, H):
    """Numbers as graphic composition — like a Swiss typographic poster."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    # Large number background
    n_big = str(random.randint(1,9))
    f_bg, _ = fit_to_width(fp, n_big, int(W*0.7), 700)
    tw,th = bb(d,n_big,f_bg)
    x,y = cxy(W,H,tw,th)
    d.text((x+10,y+10), n_big, font=f_bg, fill=(*pal["dim"][:3],180))
    d.text((x,y), n_big, font=f_bg, fill=pal["fg"])
    # Small numbers running vertically right side
    f_sm = lf(fp,28)
    for i,n in enumerate("0123456789"):
        xi = W-70; yi = 40 + i*((H-80)//10)
        col = pal["a1"] if n==n_big else pal["dim"]
        d.text((xi,yi), n, font=f_sm, fill=col)
    # Horizontal rule at golden ratio
    draw_rule(d, 40, int(H*0.618), W-40, int(H*0.618), pal["a1"], 2)
    img = grain_overlay(img, 0.04)
    return img

def layout_diagonal_sweep(fp, pal, W, H):
    """Text at dramatic angle — Bordonaro Vampire energy."""
    img = Image.new("RGB",(W,H), pal["bg"])
    word = random.choice(PUNCHY_WORDS)
    f, sz = fit_to_width(fp, word, int(W*1.1), 600)
    tmp = Image.new("RGBA",(W*2,H*2),(0,0,0,0))
    d = ImageDraw.Draw(tmp)
    tw,th = bb(d,word,f)
    # Shadow
    d.text((tmp.width//2-tw//2+6, tmp.height//2-th//2+6), word, font=f, fill=(*pal["a1"][:3],40))
    d.text((tmp.width//2-tw//2, tmp.height//2-th//2), word, font=f, fill=(*pal["fg"][:3],255))
    rot = tmp.rotate(random.choice([-35,-25,-20,20,25,35]), resample=Image.BICUBIC)
    ox = (rot.width-W)//2; oy = (rot.height-H)//2
    base = Image.new("RGB",(W,H),pal["bg"])
    crop = rot.crop((ox,oy,ox+W,oy+H))
    base.paste(Image.alpha_composite(base.convert("RGBA"),crop).convert("RGB"))
    # Accent lines
    d2 = ImageDraw.Draw(base)
    draw_rule(d2, 0, 8, W, 8, pal["a1"], 4)
    draw_rule(d2, 0, H-8, W, H-8, pal["a1"], 4)
    return grain_overlay(base, 0.05)

def layout_concentric_letters(fp, pal, W, H):
    """Same letter repeated at increasing sizes from centre — ripple effect."""
    img = Image.new("RGB",(W,H), pal["bg"])
    d = ImageDraw.Draw(img)
    ch = random.choice(list("ABCDEFGHJKMOQRSTW"))
    cx,cy = W//2, H//2
    sizes = [18,30,48,72,100,140,190,250,340]
    for i,sz in enumerate(sizes):
        f = lf(fp,sz); tw,th = bb(d,ch,f)
        t = i/(len(sizes)-1)
        # Interpolate from dim to fg
        r = int(pal["dim"][0]*(1-t)+pal["fg"][0]*t)
        g = int(pal["dim"][1]*(1-t)+pal["fg"][1]*t)
        b = int(pal["dim"][2]*(1-t)+pal["fg"][2]*t)
        d.text((cx-tw//2, cy-th//2), ch, font=f, fill=(r,g,b))
    # Accent dot at dead centre
    d.ellipse([cx-5,cy-5,cx+5,cy+5], fill=pal["a1"])
    return grain_overlay(img, 0.035)

